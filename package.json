{
  "name": "ketflix",
  "version": "2.0.3",
  "main": "backend/src/index.ts",
  "scripts": {
    "watch": "tsc --watch",
    "backend": "node --env-file ./data/process.env --watch build/backend/src/index.js",
    "dev:backend": "concurrently \"npm run watch\" \"npm run backend\"",
    "dev:frontend": "npm start --prefix ./frontend",
    "check-types": "tsc",
    "prettier": "prettier --write .",
    "build:backend": "tsc",
    "build:frontend": "npm run build --prefix ./frontend",
    "build": "tsc && npm run build:frontend"
  },
  "repository": "https://github.com/apicgg/vite-mern-template.git",
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.40.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^4.22.0",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.1",
    "package-directory": "^8.2.0",
    "puppeteer": "^25.2.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.9",
    "@types/nodemailer": "^8.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.2",
    "prettier": "3.2.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
